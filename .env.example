# airSlate SignNow API credentials
# Get these from: https://app.signnow.com/ → API → Applications

# Production: https://api.signnow.com
# Sandbox:    https://api-eval.signnow.com
SIGNNOW_API_BASE_URL=https://api-eval.signnow.com

# Base64-encoded "client_id:client_secret" from your SignNow application
SIGNNOW_BASIC_AUTH=

# Your SignNow account credentials
SIGNNOW_USERNAME=
SIGNNOW_PASSWORD=

# Optional: webhook HMAC secret for signature verification
SIGNNOW_WEBHOOK_SECRET=
